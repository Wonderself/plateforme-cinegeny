  user     User                @relation(fields: [userId], references: [id])
  film     Film?               @relation(fields: [filmId], references: [id])
  contest  TrailerContest?     @relation(fields: [contestId], references: [id])
  tasks    TrailerMicroTask[]
  choices  TrailerChoice[]

  @@index([userId, status])
  @@index([contestId])
}

model TrailerMicroTask {
  id              String              @id @default(cuid())
  projectId       String
  assigneeId      String?             // User who will execute (null = AI auto)
  taskType        TrailerTaskType
  phase           TrailerPhase
  title           String
  description     String?
  instructions    String?             // Detailed instructions for AI or human
  order           Int                 @default(0)   // Execution order within phase
  status          TrailerMicroTaskStatus @default(PENDING)
  dependsOnIds    String[]            @default([])  // IDs of tasks that must complete first
  // AI execution
  aiPrompt        String?             // The prompt sent to AI
  aiModel         String?             // Which AI model was used
  aiProvider      String?             // Provider name (runway, replicate, etc.)
  aiResult        String?             // AI output (URL or text)
  aiScore         Int?                // Quality score 0-100
  aiFeedback      String?             // AI self-evaluation
  aiRetries       Int                 @default(0)
  // User choices
  userChoice      Json?               // Options the user selected for this task
  communityVoteEnabled Boolean        @default(false)
  // Credits
  estimatedCredits Int               @default(0)
  creditsUsed     Int                 @default(0)
  rawCost         Float               @default(0)   // Real AI token cost in EUR
  commission      Float               @default(0)   // 20% commission in EUR
  // Timing
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  project  TrailerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?          @relation("TaskAssignee", fields: [assigneeId], references: [id])
  choices  TrailerChoice[]

  @@index([projectId, phase, order])
  @@index([status])
}

model TrailerChoice {
  id              String   @id @default(cuid())
  projectId       String
  taskId          String?  // Related micro-task (optional)
  question        String   // e.g. "Quel style visuel pour la scène d'ouverture?"
  category        String?  // "visual_style", "character", "music", "setting", "mood"
  options         Json     // Array of { id, label, description, imageUrl? }
  selectedOption  String?  // ID of chosen option
  isOpenToVote    Boolean  @default(false) // Community can vote
  voteDeadline    DateTime?
  votesData       Json?    // { optionId: voteCount }
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  project TrailerProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    TrailerMicroTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  votes   TrailerChoiceVote[]

  @@index([projectId])
  @@index([isOpenToVote, resolvedAt])
}

model TrailerChoiceVote {
  id        String   @id @default(cuid())
  choiceId  String
  userId    String
  optionId  String   // Which option the user voted for
  txHash    String?  // Blockchain proof
  createdAt DateTime @default(now())

  choice TrailerChoice @relation(fields: [choiceId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@unique([choiceId, userId])
}

// ============================================
// V14 — CREDIT SYSTEM (AI Token Billing)
// ============================================

model CreditAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  balance         Int      @default(0)      // Current credit balance
  totalPurchased  Int      @default(0)      // Lifetime credits purchased
  totalGranted    Int      @default(0)      // Lifetime credits granted (admin/subscription)
  totalUsed       Int      @default(0)      // Lifetime credits consumed
  totalRefunded   Int      @default(0)
  // Auto-topup settings
  autoTopupEnabled   Boolean  @default(false)
  autoTopupThreshold Int      @default(0)     // Alert when balance drops below this
  autoTopupAmount    Int      @default(0)     // Amount to request for topup
  currency           String   @default("EUR")
  stripeCustomerId   String?                  // For future Stripe integration
  weeklyFreeUsed  Int      @default(0)      // Free trailers used this week (premium)
  weeklyFreeReset DateTime @default(now())  // When weekly counter resets
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]
  holds        WalletHold[]

  @@index([userId])
}

model CreditTransaction {
  id              String        @id @default(cuid())
  userId          String
  accountId       String
  amount          Int           // Positive = add, negative = deduct
  type            CreditTxType
  description     String?
  // Billing details for AI usage
  aiProvider      String?       // "runway", "replicate", "openai", etc.
  aiModel         String?       // Specific model used
  rawTokenCount   Int?          // Raw AI tokens consumed
  rawCostEur      Float?        // Real cost in EUR
  commissionEur   Float?        // 20% commission in EUR
  totalChargedEur Float?        // rawCost + commission
  // Relations
  trailerProjectId String?
  trailerTaskId    String?
  // Metadata
  balanceBefore   Int           @default(0)
  balanceAfter    Int           @default(0)
  metadata        Json?         // Extra data (pack ID, admin note, etc.)
  createdAt       DateTime      @default(now())

  user    User          @relation(fields: [userId], references: [id])
  account CreditAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([accountId])
  @@index([type])
}

model CreditPack {
  id          String   @id @default(cuid())
  name        String   // "Starter", "Pro", "Studio"
  credits     Int      // Base credits in pack
  bonusCredits Int     @default(0)  // Extra bonus credits
  priceEur    Float    // Price in EUR
  pricePerCredit Float @default(0)  // For display: price/total credits
  description String?
  features    String[] @default([]) // Bullet points for UI
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// V14 — NEW ENUMS
// ============================================

enum TrailerProjectStatus {
  DRAFT
  DECOMPOSING      // AI is breaking down into micro-tasks
  AWAITING_INPUT   // Waiting for user choices
  IN_PROGRESS      // Tasks being executed
  COMMUNITY_VOTE   // Community voting on choices
  ASSEMBLING       // Final assembly
  REVIEW           // Quality review
  COMPLETED
  SUBMITTED        // Submitted to contest
  CANCELLED
}

enum TrailerPhase {
  CONCEPT          // Concept & brief definition
  SCRIPT           // Script, narration, dialogue
  VISUAL_DESIGN    // Character design, environments, color palette
  STORYBOARD       // Scene-by-scene storyboard
  PRODUCTION       // AI video generation per scene
  AUDIO            // Music, sound design, voiceover
  POST_PRODUCTION  // Color grading, VFX, transitions
  ASSEMBLY         // Final editing and assembly
}

enum TrailerDuration {
  TEASER_15S       // 15 second teaser
  TEASER_30S       // 30 second teaser
  STANDARD_60S     // Standard 1 minute
  EXTENDED_90S     // Extended 90 seconds
  FULL_120S        // Full 2 minute trailer
}

enum TrailerTaskType {
  // Phase: CONCEPT
  CONCEPT_BRIEF
  TARGET_AUDIENCE
  REFERENCE_MOOD_BOARD
  GENRE_TONE_DEFINITION
  // Phase: SCRIPT
  TRAILER_STRUCTURE
  NARRATION_SCRIPT
  DIALOGUE_SNIPPETS
  KEY_MOMENTS
  // Phase: VISUAL_DESIGN
  CHARACTER_DESIGN_MAIN
  CHARACTER_DESIGN_SECONDARY
  ENVIRONMENT_DESIGN
  PROPS_DESIGN
  COLOR_PALETTE_DESIGN
  TYPOGRAPHY_TITLES
  // Phase: STORYBOARD
  SCENE_STORYBOARD_HOOK
  SCENE_STORYBOARD_INTRO
  SCENE_STORYBOARD_BUILD
  SCENE_STORYBOARD_CLIMAX
  SCENE_STORYBOARD_TAG
  TRANSITION_PLANNING
  // Phase: PRODUCTION
  SCENE_VIDEO_GEN_HOOK
  SCENE_VIDEO_GEN_INTRO
  SCENE_VIDEO_GEN_BUILD
  SCENE_VIDEO_GEN_CLIMAX
  SCENE_VIDEO_GEN_TAG
  TITLE_CARD_GEN
  VFX_OVERLAY_GEN
  // Phase: AUDIO
  MUSIC_SELECTION
  MUSIC_GENERATION
  SOUND_EFFECTS
  VOICEOVER_GEN
  DIALOGUE_RECORDING
  // Phase: POST_PRODUCTION
  COLOR_GRADING
  VFX_COMPOSITING
  TRANSITION_EFFECTS
  SUBTITLE_GEN
  // Phase: ASSEMBLY
  ROUGH_CUT
  FINAL_ASSEMBLY
  QUALITY_REVIEW
  EXPORT_FORMATS
}

enum TrailerMicroTaskStatus {
  PENDING          // Not started yet
  BLOCKED          // Waiting for dependencies
  READY            // Dependencies met, ready to execute
  GENERATING       // AI is working on it
  AWAITING_CHOICE  // Waiting for user/community choice
  IN_REVIEW        // Generated, needs review
  APPROVED         // Approved, moving on
  REJECTED         // Rejected, needs redo
  COMPLETED        // Done
  SKIPPED          // Skipped by user
}

enum CreditTxType {
  PACK_PURCHASE      // Bought a credit pack
  ADMIN_GRANT        // Admin manually granted credits
  SUBSCRIPTION_GRANT // Weekly free credits from subscription
  AI_USAGE           // Used credits for AI generation
  REFUND             // Refunded credits
  CONTEST_PRIZE      // Won credits from contest
  REFERRAL_BONUS     // Referral reward
  PROMO_CODE         // Promotional code
  HOLD               // Credits held before AI action
  HOLD_RELEASE       // Credits refunded from hold overestimate
  HOLD_OVERAGE       // Additional charge when actual > estimated
  AUTO_TOPUP         // Auto-topup deposit
  EXPIRY             // Expired credits
}

// ============================================
// V15 — USER FILM PROJECTS (Create Pipeline)
// ============================================

model UserFilmProject {
  id              String   @id @default(cuid())
  userId          String
  title           String
  genre           String?
  logline         String?
  thumbnail       String?  // URL or base64
  status          UserFilmStatus @default(DRAFT)
  completedSteps  String[] // Array of step IDs: ["script","storyboard","casting",...]
  currentStep     String?  // Current active step
  isPaid          Boolean  @default(false) // $9 pay-per-use
  paymentIntentId String?  // Stripe payment intent
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  script     UserFilmScript?
  storyboard UserFilmStoryboard?
  characters UserFilmCharacter[]
  locations  UserFilmLocation[]
  stills     UserFilmStill[]
  videos     UserFilmVideo[]
  music      UserFilmMusic[]

  @@index([userId, updatedAt])
}

model UserFilmScript {
  id          String   @id @default(cuid())
  projectId   String   @unique
  content     String   // Full script text
  genres      String[] // Multi-select genres
  logline     String?
  pageCount   Int?
  aiScore     Json?    // { structure: 72, character: 85, pacing: 68, dialogue: 78 }
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project UserFilmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model UserFilmStoryboard {
  id        String   @id @default(cuid())
  projectId String   @unique
  frames    Json     // Array of { id, label, prompt, imageUrl, shotType, aspectRatio, description, order }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project UserFilmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model UserFilmCharacter {
  id            String   @id @default(cuid())
  projectId     String
  name          String
  role          String?  // protagonist, antagonist, supporting...
  backstory     String?
  motivation    String?
  voiceType     String?
  photoUrl      String?
  generatedUrl  String?  // AI-generated portrait
  dialogueLines Int      @default(0)
  screenTime    String?  // "5-10 min", "10-20 min"...
  sortOrder     Int      @default(0)
  // Marketplace
  isOnMarketplace Boolean @default(false)
  marketplacePrice Float?  // Min €1
  marketplaceTags  String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project     UserFilmProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  purchases   CharacterPurchase[]
  relationships CharacterRelationship[]

  @@index([projectId])
  @@index([isOnMarketplace])
}

model CharacterRelationship {
  id          String @id @default(cuid())
  characterId String
  targetName  String // Name of related character
  type        String // ally, rival, mentor, love_interest, family, neutral

  character UserFilmCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
}

model CharacterPurchase {
  id          String   @id @default(cuid())
  characterId String
  buyerId     String
  sellerId    String
  price       Float
  commission  Float    // 30% platform fee
  stripePaymentId String?
  createdAt   DateTime @default(now())

  character UserFilmCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  buyer     User              @relation("CharacterBuyer", fields: [buyerId], references: [id])
  seller    User              @relation("CharacterSeller", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
}

model UserFilmLocation {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  imageUrl    String?  // AI-generated or uploaded
  isSelected  Boolean  @default(false)
  moodBoard   String[] // Array of image URLs
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  project UserFilmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model UserFilmStill {
  id        String   @id @default(cuid())
  projectId String
  prompt    String
  style     String?
  imageUrl  String
  isSelected Boolean @default(false)
  createdAt DateTime @default(now())

  project UserFilmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model UserFilmVideo {
  id          String   @id @default(cuid())
  projectId   String
  prompt      String?
  thumbnailUrl String?
  videoUrl    String?  // When real video gen is available
  duration    Int?     // Seconds
  sortOrder   Int      @default(0) // Position in timeline
  isInTimeline Boolean @default(false)
  createdAt   DateTime @default(now())

  project UserFilmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model UserFilmMusic {
  id        String   @id @default(cuid())
  projectId String
  title     String
  mood      String?
  tempo     String?  // "slow", "medium", "fast"
  duration  Int?     // Seconds
  audioUrl  String?  // When real audio gen is available
  isSelected Boolean @default(false)
  createdAt DateTime @default(now())

  project UserFilmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================
// V15 — TOKEN USAGE & STORAGE TRACKING
// ============================================

model TokenUsageLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "script_analysis", "image_generation", "video_generation", "music_generation"
  credits   Int      // Credits consumed
  projectId String?  // Link to UserFilmProject
  metadata  Json?    // Extra info (prompt, model used, etc.)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action])
}

model StorageUsage {
  id        String   @id @default(cuid())
  userId    String
  fileType  String   // "image", "video", "audio", "script"
  fileUrl   String
  sizeBytes BigInt
  projectId String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserFilmStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

// ============================================
// V16 — PRODUCTION SHARES & SMART CONTRACTS
// ============================================

model ProductionShare {
  id              String   @id @default(cuid())
  filmId          String   // Can be CatalogFilm or UserFilmProject
  userId          String
  shareType       ShareType
  percentage      Float    // % of the film they own (e.g. 0.5 = 0.5%)
  acquiredVia     ShareAcquisition
  contractAddress String?  // Ethereum smart contract address
  txHash          String?  // Blockchain transaction hash
  chainId         Int      @default(1) // 1=Ethereum mainnet, 42161=Arbitrum
  isLocked        Boolean  @default(true) // Locked until film release
  lockUntil       DateTime? // When shares unlock
  canResell       Boolean  @default(false) // No resale — buyback by platform only
  buybackPrice    Float?   // Platform buyback price if requested
  pricePaid       Float?   // If acquired via investment
  currency        String   @default("ETH") // ETH, USDC, USD
  aiEstimatedPct  Float?   // AI-calculated fair share for workers
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([filmId, userId])
  @@index([userId])
}

model RevenueDistribution {
  id              String   @id @default(cuid())
  filmId          String
  totalRevenue    Float
  distributionDate DateTime
  contractAddress String?  // Smart contract that executed distribution
  txHash          String?
  status          DistributionStatus @default(PENDING)
  createdAt       DateTime @default(now())

  payouts RevenuePayoutLine[]

  @@index([filmId])
}

model RevenuePayoutLine {
  id              String   @id @default(cuid())
  distributionId  String
  userId          String
  sharePercentage Float    // Their % at time of distribution
  amount          Float    // Amount paid out
  currency        String   @default("EUR")
  paymentMethod   V16PaymentMethod @default(FIAT)
  txHash          String?  // If crypto payment
  status          V16PayoutStatus @default(PENDING)
  createdAt       DateTime @default(now())

  distribution RevenueDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id])

  @@index([distributionId])
  @@index([userId])
}

model WorkTask {
  id          String   @id @default(cuid())
  filmId      String
  title       String
  description String?
  category    TaskCategory
  difficulty  TaskDifficulty @default(MEDIUM)
  estimatedMinutes Int @default(30)
  rewardCash  Float?   // Cash reward in EUR
  rewardShares Float?  // Production share % offered
  status      WorkTaskStatus @default(OPEN)
  assigneeId  String?
  completedAt DateTime?
  reviewedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignee User? @relation("WorkTaskAssignee", fields: [assigneeId], references: [id])

  @@index([filmId, status])
  @@index([assigneeId])
  @@index([category])
}

model ScenarioSubmission {
  id          String   @id @default(cuid())
  userId      String
  title       String
  logline     String?
  content     String   // Full script text
  genre       String?
  pageCount   Int?
  sharePercent      Float   @default(5)  // Base 5% of net film revenue
  shareTier         String  @default("base") // base=5%, challenge=7%, top10=10%
  adminOverridePct  Float?  // Admin can manually set any percentage
  bestVoteRank      Int?    // Highest vote ranking achieved
  challengeBonus    Boolean @default(false) // Earned challenge bonus
  status            ScenarioStatus @default(SUBMITTED)
  reviewNote        String?
  filmId            String?  // If accepted, links to the film
  paidAmount        Float?   // $9 submission fee
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model ActInsertion {
  id          String   @id @default(cuid())
  userId      String
  filmId      String
  photoUrl    String
  roleType    String   // lead, supporting, cameo, voice, narrator
  sceneIndex  Int?     // Which scene they appear in
  quality     String   @default("standard") // standard ($9) or premium ($29)
  exportUrl   String?  // Generated video URL
  contractNote String? // On-chain reference for likeness rights
  status      InsertionStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([filmId])
}

// ============================================
// V17 — VOTING, POINTS & PLATFORM FEES
// ============================================

model VoteStake {
  id          String   @id @default(cuid())
  userId      String
  filmId      String
  stakeAmount Int      @default(1)  // Points staked on this vote
  voteType    String   // "APPROVE" or "REJECT"
  pointsEarned Int     @default(0) // Points earned if vote aligned with outcome
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([filmId])
  @@unique([userId, filmId]) // One vote per user per film
}

model PointsTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // Positive = earned, negative = spent
  reason      PointsReason
  referenceId String?  // filmId, voteId, etc.
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PlatformFee {
  id              String   @id @default(cuid())
  filmId          String
  creatorId       String   // Film creator's userId
  isExclusive     Boolean  @default(true) // true = 25% fee, false = 33% fee
  feePercentage   Float    // 25.0 or 33.0
  aiVerifiedAt    DateTime? // When AI agent last verified distribution status
  aiVerifiedStatus String?  // "exclusive_confirmed" | "external_detected" | "pending"
  externalPlatforms String[] @default([]) // URLs where film was detected
  totalRevenue    Float    @default(0)
  platformCut     Float    @default(0) // feePercentage * totalRevenue / 100
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([filmId])
  @@index([creatorId])
}

model FilmSubmission {
  id          String   @id @default(cuid())
  filmId      String   // Reference to CatalogFilm or UserFilmProject
  creatorId   String
  title       String
  trailerUrl  String?  // Trailer video URL
  pitchText   String?  // Short pitch
  votesFor    Int      @default(0)
  votesAgainst Int     @default(0)
  totalStaked Int      @default(0) // Total points staked
  status      FilmSubmissionStatus @default(PENDING_VOTE)
  reviewedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([creatorId])
  @@index([status])
}

// ============================================
// V18 — PAY-PER-VIEW & VIEW REVENUE
// ============================================

model PPVPurchase {
  id          String      @id @default(cuid())
  userId      String
  purchaseType PPVType
  filmId      String?     // null for day pass or pack
  amount      Float       // EUR amount paid
  currency    String      @default("EUR")
  paymentMethod String    @default("stripe") // stripe, crypto, points
  validUntil  DateTime?   // For day pass
  filmsRemaining Int?     // For pack (starts at 5)
  txHash      String?     // Blockchain tx
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([filmId])
}

model ViewRevenuePool {
  id              String   @id @default(cuid())
  filmId          String
  periodStart     DateTime // Monthly period
  periodEnd       DateTime
  totalViews      Int      @default(0)
  adRevenue       Float    @default(0)
  subscriptionRevenue Float @default(0) // Proportional share from sub pool
  ppvRevenue      Float    @default(0)
  totalRevenue    Float    @default(0) // Sum of all
  distributed     Boolean  @default(false)
  distributedAt   DateTime?
  createdAt       DateTime @default(now())

  @@index([filmId])
  @@unique([filmId, periodStart])
}

// ============================================
// V19 — TV UNIVERSE
// ============================================

model TvShow {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  genre           String
  host            String?
  synopsis        String?      @db.Text
  format          String?      // Talk Show, Game Show, etc.
  episodeCount    Int          @default(0)
  seasonCount     Int          @default(1)
  duration        Int          @default(30) // minutes per episode
  rating          Float        @default(0)
  viewCount       Int          @default(0)
  coverImageUrl   String?
  status          TvShowStatus @default(CONCEPT)
  fundingGoal     Float        @default(0)
  fundingRaised   Float        @default(0)
  chainId         Int          @default(1) // Ethereum mainnet
  contractAddress String?
  creatorId       String?
  episodes        TvEpisode[]
  schedules       TvSchedule[]
  tags            String[]
  premiered       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([genre])
  @@index([status])
  @@index([creatorId])
}

model TvEpisode {
  id            String   @id @default(cuid())
  showId        String
  show          TvShow   @relation(fields: [showId], references: [id], onDelete: Cascade)
  title         String
  season        Int      @default(1)
  episode       Int
  synopsis      String?  @db.Text
  duration      Int      @default(30)
  thumbnailUrl  String?
  videoUrl      String?
  viewCount     Int      @default(0)
  airedAt       DateTime?
  createdAt     DateTime @default(now())

  @@unique([showId, season, episode])
  @@index([showId])
}

model TvSchedule {
  id        String   @id @default(cuid())
  showId    String
  show      TvShow   @relation(fields: [showId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0=Sunday, 6=Saturday
  startTime String   // "20:00"
  endTime   String   // "21:00"
  isLive    Boolean  @default(false)
  recurring Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([showId])
  @@index([dayOfWeek])
}

